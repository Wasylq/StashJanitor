# Compiled binaries — built into the working tree by `go build`
/sfx
/cmd/sfx/sfx

# SQLite cache files (defaults to ./sfx.sqlite, plus WAL/SHM siblings)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Local config: generated by `sfx config init` and may contain instance-
# specific URLs or notes. Never commit a real user config.
config.yaml
config.local.yaml
config.*.yaml

# Test artifacts
coverage.out
coverage.txt
*.test
*.prof

# Go vendor directory (we don't vendor; protect against accidental commits)
/vendor/

# Editor / IDE / OS detritus
.idea/
.vscode/
*.swp
*.swo
.DS_Store
*~

# Local-only Claude Code state for this project
.claude/
